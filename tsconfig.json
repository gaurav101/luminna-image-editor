{
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "paths": {
      "lumina-editor": ["src/index.ts"],
      "lumina-editor/style-presets": ["src/stylePresets.ts"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["vitest/globals", "vite/client"],
    "useDefineForClassFields": true
  },
  "include": [
    "src",
    "demo",
    "demo/.storybook",
    "vite.config.ts",
    "vite.style-presets.config.ts",
    "eslint.config.js",
    "vitest.setup.ts"
  ]
}
